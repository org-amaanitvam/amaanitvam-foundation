# ── Server ────────────────────────────────────────────────────────────
PORT=8001
ENVIRONMENT=development

# ── PostgreSQL ────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/amaanitvam_ai

# ── ChromaDB ─────────────────────────────────────────────────────────
# Local persistent directory for embeddings (Phase 1)
CHROMA_PERSIST_DIR=./chroma_data

# ── LLM (Google Gemini) ───────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=text-embedding-004

# ── Internal Auth ─────────────────────────────────────────────────────
# MUST match INTERNAL_SHARED_SECRET in server/.env
INTERNAL_SHARED_SECRET=change_this_to_a_strong_shared_secret

# ── Main Node.js API ──────────────────────────────────────────────────
MAIN_API_URL=http://localhost:5000
